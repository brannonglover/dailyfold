{
  "name": "dailyfold",
  "main": "index.js",
  "version": "2.6.0",
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/lora": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.106.2",
    "expo": "~54.0.0",
    "expo-background-task": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-task-manager": "~14.0.9",
    "expo-video": "~3.0.16",
    "expo-web-browser": "~15.0.11",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2"
  },
  "scripts": {
    "postinstall": "node scripts/patch-expo-cli.mjs",
    "version:sync": "node scripts/sync-version.js",
    "version": "node scripts/sync-version.js",
    "eas-build-pre-install": "node scripts/sync-version.js --with-build-number",
    "start": "expo start --dev-client --host lan",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "api": "NODE_OPTIONS='--use-system-ca' node scripts/start-api.mjs",
    "api:ingest": "NODE_OPTIONS='--use-system-ca' npm run ingest --prefix backend",
    "api:watch": "NODE_OPTIONS='--use-system-ca' npm run ingest:watch --prefix backend",
    "api:stop": "node scripts/api-check.mjs stop",
    "api:check": "node scripts/api-check.mjs probe",
    "api:restart": "node scripts/api-check.mjs stop && node scripts/start-api.mjs",
    "vercel:backend": "vercel",
    "vercel:backend:prod": "vercel --prod"
  },
  "private": true
}
