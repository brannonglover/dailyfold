# Supabase Auth (required for sign-in / account features)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Backend API
# Local iOS Simulator: http://localhost:3001
# Physical device (dev): omit (Metro LAN auto-detect) or set your Mac's LAN IP,
# e.g. http://192.168.1.94:3001
# Production / TestFlight: your deployed API URL, e.g. https://your-app.vercel.app
EXPO_PUBLIC_API_URL=http://localhost:3001
