# Point the app at your local API (Next.js backend).
# iOS Simulator: http://localhost:3001
# Physical device: omit this line (Metro LAN auto-detect) or set your Mac's LAN IP,
# e.g. http://192.168.1.94:3001 — localhost in .env only works in the simulator.
# EXPO_PUBLIC_API_URL=http://192.168.1.94:3001
