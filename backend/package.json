{
  "name": "dailyfold-api",
  "version": "2.7.0",
  "private": true,
  "scripts": {
    "dev": "WATCHPACK_POLLING=true CHOKIDAR_USEPOLLING=true NODE_OPTIONS='--use-system-ca' next dev -p 3001 -H 0.0.0.0",
    "build": "next build",
    "start": "NODE_OPTIONS='--use-system-ca' next start -p 3001",
    "ingest": "NODE_OPTIONS='--use-system-ca' tsx --env-file=.env scripts/ingest.ts",
    "ingest:watch": "NODE_OPTIONS='--use-system-ca' tsx --env-file=.env scripts/ingest-watch.ts",
    "test:subscription": "tsx lib/subscription.detect.test.ts",
    "test:image": "tsx lib/normalize.image.test.ts",
    "test:feedMedia": "tsx --test lib/feedMedia.test.ts",
    "test:ogImage": "tsx --test lib/ogImage.test.ts",
    "test:publishedAt": "tsx --test lib/normalize.publishedAt.test.ts",
    "test:excerpt": "tsx lib/normalize.excerpt.test.ts",
    "test:embeddedMedia": "tsx --test lib/embeddedMedia.test.ts",
    "test:readerCache": "tsx --test lib/readerCache.test.ts",
    "test:search": "tsx --test lib/db.search.test.ts",
    "db:migrate": "NODE_OPTIONS='--use-system-ca' tsx --env-file=.env scripts/migrate.ts"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@supabase/supabase-js": "^2.106.2",
    "drizzle-orm": "^0.44.2",
    "linkedom": "^0.18.12",
    "next": "^15.3.3",
    "postgres": "^3.4.9",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.6",
    "tsx": "^4.19.4",
    "typescript": "^5.9.2"
  }
}
