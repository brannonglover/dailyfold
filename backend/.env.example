INGEST_INTERVAL_MS=1800000
MAX_ARTICLE_AGE_DAYS=30
ITEMS_PER_FEED=50
CRON_SECRET=dev-secret-change-in-production

# Optional. On Vercel, defaults to /tmp/beacon.db (serverless filesystem is read-only elsewhere).
# DATABASE_PATH=/tmp/beacon.db

# Account deletion (Supabase Auth admin API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
