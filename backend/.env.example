INGEST_INTERVAL_MS=1800000
MAX_ARTICLE_AGE_DAYS=30
ITEMS_PER_FEED=50
CRON_SECRET=dev-secret-change-in-production

# Optional. Set to 1 for progress logs during API-triggered ingest.
# INGEST_VERBOSE=1

# Parallel publisher-page fetches when RSS omits a hero image (default: 10).
# OG_IMAGE_CONCURRENCY=10

# Article store (Supabase Postgres). Use the "Transaction" pooler connection
# string (Supabase dashboard → Settings → Database → Connection string →
# Transaction mode, port 6543) — required so serverless functions don't
# exhaust the direct connection limit. After setting this, run:
#   npm run db:migrate
DATABASE_URL=postgresql://postgres.your-project:password@aws-0-region.pooler.supabase.com:6543/postgres

# Account deletion (Supabase Auth admin API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
